# Copy to .env and fill in, or export these as real environment variables
# before running the server.

DJANGO_SECRET_KEY=change-me-to-something-random
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*
DJANGO_TIME_ZONE=Europe/Athens

# --- Viber (Public Account / Bot) ---
# Create a bot at partners.viber.com, get its auth token.
# Recipients must message the bot once before it can message them back
# (that's how you get their viber_user_id to put in the Recipient admin page).
VIBER_BOT_AUTH_TOKEN=
VIBER_SENDER_NAME=Climate Monitor

# --- SMS (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Behaviour ---
NOTIFICATION_COOLDOWN_MINUTES=15
DEVICE_OFFLINE_AFTER_MINUTES=10
