# Copy this file to .env and fill in your real values.
# Φορτώνεται ΑΥΤΟΜΑΤΑ από το Django (μέσω python-dotenv) - δεν χρειάζεται
# κανένα χειροκίνητο "export" σε Windows/Mac/Linux.

DJANGO_SECRET_KEY=change-me-to-something-random
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*
DJANGO_TIME_ZONE=Europe/Athens

# --- SMS (μέσω Android κινητού ως gateway, π.χ. SMSGate app - sms-gate.app) ---
# Δωρεάν, χωρίς εγγραφή/κάρτα, χωρίς Twilio. Εγκατέστησε το app σε ένα Android
# κινητό/tablet με SIM κάρτα, και βάλε εδώ τα στοιχεία που σου δίνει:
SMS_GATEWAY_URL=
SMS_GATEWAY_USERNAME=
SMS_GATEWAY_PASSWORD=

# --- Behaviour ---
NOTIFICATION_COOLDOWN_MINUTES=15
DEVICE_OFFLINE_AFTER_MINUTES=10
